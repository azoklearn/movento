# Whop API — company settings > developer
WHOP_API_KEY=whop_xxxxxxxxxxxxxxxxxxxxx
WHOP_COMPANY_ID=biz_xxxxxxxxx

# Webhook signing secret (Whop dashboard > webhooks)
WHOP_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Hosted Whop checkout links, one per plan
WHOP_MONTHLY_URL=https://whop.com/checkout/plan_xxxxxxxxx
WHOP_YEARLY_URL=https://whop.com/checkout/plan_xxxxxxxxx
WHOP_LIFETIME_URL=https://whop.com/checkout/plan_xxxxxxxxx

# Where customers manage/cancel their membership (optional)
WHOP_PORTAL_URL=https://whop.com/orders/

CLIENT_URL=http://localhost:5173
