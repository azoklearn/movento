# Whop API — company settings > developer
WHOP_API_KEY=whop_xxxxxxxxxxxxxxxxxxxxx
WHOP_COMPANY_ID=biz_xxxxxxxxx

# Webhook signing secret (Whop dashboard > webhooks)
WHOP_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Hosted Whop checkout links, one per plan.
# For the ON-SITE embedded checkout (no redirect), use the plan-link form below
# (https://whop.com/checkout/plan_xxx) — the plan_xxx id is extracted from it.
# A product-page link (e.g. https://whop.com/movento/acces-lifetime/) still works
# but falls back to redirecting to the hosted page.
WHOP_MONTHLY_URL=https://whop.com/checkout/plan_xxxxxxxxx
WHOP_YEARLY_URL=https://whop.com/checkout/plan_xxxxxxxxx
WHOP_LIFETIME_URL=https://whop.com/checkout/plan_xxxxxxxxx

# Optional: set the Whop plan id (plan_xxx) explicitly to force embedded checkout
# even when the *_URL above is a product-page link. Find it in the Whop dashboard
# under the plan's checkout link. Takes precedence over the *_URL extraction.
WHOP_MONTHLY_PLAN_ID=
WHOP_YEARLY_PLAN_ID=
WHOP_LIFETIME_PLAN_ID=

# Where customers manage/cancel their membership (optional)
WHOP_PORTAL_URL=https://whop.com/orders/

CLIENT_URL=http://localhost:5173
